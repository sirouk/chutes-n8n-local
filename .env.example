# Deployment mode
INSTALL_MODE="domain"
CHUTES_COMPOSE_FILES="docker-compose.yml:docker-compose.domain.yml"
EDGE_SERVICE="caddy"
E2EE_PROXY_IMAGE="parachutes/e2ee-proxy:latest"

# Pinned n8n source
N8N_VERSION="2.12.1"
N8N_SOURCE_REPO="https://github.com/n8n-io/n8n.git"
N8N_SOURCE_REF="n8n@2.12.1"
TZ="UTC"

# Domain installs
N8N_HOST="n8n.example.com"
ACME_EMAIL="ops@example.com"

# Database (auto-generated by bootstrap.sh)
POSTGRES_USER="n8n"
POSTGRES_PASSWORD=""
POSTGRES_DB="n8n"

# n8n secrets (auto-generated by bootstrap.sh)
# WARNING: N8N_ENCRYPTION_KEY encrypts stored credentials.
# Rotating it will strand all existing n8n credentials.
N8N_ENCRYPTION_KEY=""
N8N_JWT_SECRET=""
N8N_ADMIN_EMAIL="admin@chutes.local"
N8N_ADMIN_PASSWORD=""
N8N_EXPIRABLE_CREDENTIAL_REFRESH_WINDOW_SECONDS="300"

# Chutes SSO
CHUTES_OAUTH_CLIENT_ID=""
CHUTES_OAUTH_CLIENT_SECRET=""
CHUTES_IDP_BASE_URL="https://api.chutes.ai"
CHUTES_SSO_LOGIN_LABEL="Continue with Chutes"
CHUTES_SSO_SCOPES="openid profile chutes:read chutes:invoke"
CHUTES_ADMIN_USERNAMES=""

# Optional bootstrap credential import
CHUTES_API_KEY=""
